# BI Agent — Production Environment
# Copy to .env and fill in real values
# NEVER commit this file with real credentials

# ── AI Provider ────────────────────────────────────────────────────────────────
AI_PROVIDER=ollama                          # ollama | gemini | claude
OLLAMA_MODEL=qwen2.5:latest
OLLAMA_URL=http://ollama:11434              # docker service name

# GEMINI_API_KEY=your_gemini_key_here       # uncomment if using Gemini
# ANTHROPIC_API_KEY=your_claude_key_here    # uncomment if using Claude

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://bi_user:bi_secret@postgres:5432/bi_agent
REDIS_URL=redis://redis:6379/0

# ── Security ───────────────────────────────────────────────────────────────────
AGENT_API_KEY=change-this-in-production-use-long-random-string
ADMIN_API_KEY=change-this-in-production-use-long-random-string

# ── Output ─────────────────────────────────────────────────────────────────────
REPORTS_DIR=/app/reports

# ── Optional: Email Notifications ──────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your_app_password
# NOTIFY_EMAIL=recipient@company.com

# ── Optional: Slack Notifications ─────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
